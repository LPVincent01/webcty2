  <DataSources>
    <DataSource Name="KiemKeDataSource">
      <rd:SecurityType>DataBase</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=192.168.11.207;Initial Catalog=QuanlyThietBi</ConnectString>
        <Prompt>Specify a user name and password for data source KiemKeDataSource:</Prompt>
      </ConnectionProperties>
      <rd:DataSourceID>95d6f9d6-8ba1-46b2-b1f6-9bbb0c1c6d2a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>KiemKeDataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@pDotID">
            <Value>=Parameters!pDotID.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>SELECT
    d.DotID,
    d.TenDot,
    d.NgayBatDau,
    c.MaThietBi,
    c.TrangThaiThucTe,
    c.ThoiGianQuet
FROM DOTKIEMKE d
LEFT JOIN KIEMKECHITIET c ON d.DotID = c.DotID
WHERE (@pDotID = 0 OR d.DotID = @pDotID)</CommandText>
      </Query>
      <Fields>
        <Field Name="DotID">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>DotID</DataField>
        </Field>
        <Field Name="TenDot">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TenDot</DataField>
        </Field>
        <Field Name="NgayBatDau">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>NgayBatDau</DataField>
        </Field>
        <Field Name="MaThietBi">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>MaThietBi</DataField>
        </Field>
        <Field Name="TrangThaiThucTe">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TrangThaiThucTe</DataField>
        </Field>
        <Field Name="ThoiGianQuet">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ThoiGianQuet</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsDotList">
      <Query>
        <DataSourceName>KiemKeDataSource</DataSourceName>
        <CommandText>SELECT 0 AS DotID, N'Tất cả' AS TenDot
UNION ALL
SELECT DotID, TenDot
FROM DOTKIEMKE
ORDER BY DotID</CommandText>
      </Query>
      <Fields>
        <Field Name="DotID">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>DotID</DataField>
        </Field>
        <Field Name="TenDot">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>TenDot</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
